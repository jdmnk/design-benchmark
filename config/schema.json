{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Design Bench config",
  "type": "object",
  "required": ["name", "prompt", "models"],
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string", "description": "Run name; also the results/<name> folder." },
    "description": { "type": "string" },
    "systemPrompt": { "type": "string", "description": "System message sent to every model." },
    "prompt": { "type": "string", "description": "The single design brief sent to every model." },
    "render": {
      "type": "object",
      "properties": {
        "viewportWidth": { "type": "integer" },
        "viewportHeight": { "type": "integer" },
        "deviceScaleFactor": { "type": "number" },
        "fullPage": { "type": "boolean" },
        "maxFullPageHeight": { "type": "integer" },
        "waitMs": { "type": "integer" },
        "screenshotTimeoutMs": { "type": "integer" },
        "seed": { "type": "integer" },
        "freezeClock": { "type": "boolean" },
        "video": {
          "type": "object",
          "description": "Capture an animated clip instead of a single frame (requires freezeClock). Frames are captured by stepping the virtual clock, then encoded to per-model clip.mp4 files and one composed grid.mp4.",
          "required": ["durationMs", "fps"],
          "properties": {
            "durationMs": { "type": "integer", "description": "Clip length." },
            "fps": { "type": "integer", "description": "Frame rate of the clip and the virtual-clock step." },
            "preRollMs": { "type": "integer", "description": "Virtual time advanced before recording starts." }
          }
        }
      }
    },
    "grid": {
      "type": "object",
      "properties": {
        "columns": { "type": "integer", "minimum": 1 },
        "cellWidth": { "type": "integer" },
        "padding": { "type": "integer" },
        "background": { "type": "string" },
        "labelHeight": { "type": "integer" },
        "labelColor": { "type": "string" },
        "labelFontSize": { "type": "integer" },
        "title": { "type": "string" },
        "labelStyle": { "type": "string", "enum": ["banner", "overlay", "topbar"], "description": "banner = caption strip above each cell; overlay = pill over the render's top-left; topbar = thin one-line strip across the top of the render." },
        "labelOverlayBg": { "type": "string", "description": "Background color of the overlay pill (supports rgba)." }
      }
    },
    "generation": {
      "type": "object",
      "properties": {
        "temperature": { "type": "number" },
        "maxTokens": { "type": "integer" },
        "concurrency": { "type": "integer", "minimum": 1 },
        "timeoutMs": { "type": "integer" },
        "retries": { "type": "integer", "minimum": 0 },
        "reasoningEffort": { "type": "string", "enum": ["minimal", "low", "medium", "high"], "description": "Cap reasoning-token spend for hybrid-reasoning models so they don't burn the whole budget thinking and return empty content." }
      }
    },
    "models": {
      "description": "Inline array of models, or a path (relative to this config) to a JSON file containing such an array.",
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["slug", "label", "provider", "id"],
            "properties": {
              "slug": { "type": "string" },
              "label": { "type": "string" },
              "provider": { "type": "string", "enum": ["openrouter", "openai", "anthropic"] },
              "id": { "type": "string" },
              "temperature": { "type": "number" },
              "maxTokens": { "type": "integer" },
              "reasoningEffort": { "type": "string", "enum": ["minimal", "low", "medium", "high"] },
              "skipByDefault": { "type": "boolean" }
            }
          }
        }
      ]
    }
  }
}
