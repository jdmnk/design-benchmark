# Primary provider. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional: generic OpenAI-compatible provider (OpenAI, Together, Groq, local vLLM, ...)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: native Anthropic provider
# ANTHROPIC_API_KEY=sk-ant-...

# Optional attribution headers used by OpenRouter rankings
# OPENROUTER_REFERRER=https://github.com/you/design-bench
# OPENROUTER_TITLE=design-bench
